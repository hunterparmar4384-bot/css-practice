#include<conio.h>
#include<stdio.h>
void main()
{
	int num,last,rev=0, t;

	clrscr();
	printf("Enter number:");
	scanf("%d",&num);
	t = num;
	while(num>0)
	{
		last = num % 10;
		rev  = rev*10+last;
		num  = num / 10;

	}
	printf("rev=%d , t=%d\n",rev,t);

	if(t == rev)
	{
		printf("same");
	}
	else
	{
		printf("not same");

	}
	getch();

}
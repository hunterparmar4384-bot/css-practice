#include<stdio.h>
#include<conio.h>
void main()
{
	int a[3][3];
	int i,j,sum=0;
	clrscr();

	for(i=0;i<3;i++)
	{
		for(j=0;j<3;j++)
		{
			printf("a[%d][%d]:",i,j);
			scanf("%d",&a[i][j]);
			sum = sum + a[i][j];
		}
	}
	for(i=0;i<3;i++)
	{
		for(j=0;j<3;j++)
		{

			printf("%d\t",a[i][j]);

		}
		printf("\n");


	}
	printf("Total sum=%d",sum);
	getch();
}

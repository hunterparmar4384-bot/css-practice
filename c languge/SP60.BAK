#include<stdio.h>
#include<conio.h>
void main()
{
	int a[3][3];
	int i,j,min;
	clrscr();

	for(i=0;i<3;i++)
	{

		for(j=0;j<3;j++)
		{
			printf("a[%d][%d]:",i,j);
			scanf("%d",&a[i][j]);
		}
	}
	for(i=0;i<3;i++)
	{
		min = a[i][0];
		for(j=0;j<3;j++)
		{
			if(a[i][j]<min)
			{
				min=a[i][j];
			}
			printf("%d\t",a[i][j]);
		}
		printf("min number;%d",min);
		printf("\n");

	}
	getch();

}